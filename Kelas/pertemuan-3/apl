#include <iostream>
#include <iomanip>
using namespace std;

struct Mahasiswa {
    string nama;
    string nim;
    int hadir;
};

Mahasiswa data[100];
int jumlah = 0;

void tambahData() {
    cout << "\n=== Tambah Mahasiswa ===\n";
    cout << "Nama  : "; cin.ignore(); getline(cin, data[jumlah].nama);
    cout << "NIM   : "; cin >> data[jumlah].nim;
    cout << "Hadir : "; cin >> data[jumlah].hadir;
    jumlah++;
    cout << "Data berhasil ditambahkan!\n";
}

void tampilData() {
    if (jumlah == 0) {
        cout << "\nData kosong!\n";
        return;
    }

    cout << "\n=============================================================\n";
    cout << "| No | " << left << setw(20) << "Nama"
         << "| " << setw(15) << "NIM"
         << "| " << setw(10) << "Hadir" << "|\n";
    cout << "=============================================================\n";

    for (int i = 0; i < jumlah; i++) {
        cout << "| " << setw(2) << i+1 << " | "
             << setw(20) << data[i].nama << "| "
             << setw(15) << stoi(data[i].nim) << "| "  
             << setw(10) << data[i].hadir << "|\n";
    }

    cout << "=============================================================\n";
}

void cariData() {
    string cari;
    cout << "\nMasukkan NIM yang dicari: ";
    cin >> cari;

    bool ditemukan = false;
    for (int i = 0; i < jumlah; i++) {
        if (data[i].nim == cari) {
            cout << "\nData ditemukan!\n";
            cout << "Nama  : " << data[i].nama << endl;
            cout << "NIM   : " << stoi(data[i].nim) << endl;
            cout << "Hadir : " << data[i].hadir << endl;
            ditemukan = true;
            break;
        }
    }

    if (!ditemukan) {
        cout << "Data tidak ditemukan!\n";
    }
}

void hapusData() {
    string hapus;
    cout << "\nMasukkan NIM yang ingin dihapus: ";
    cin >> hapus;

    bool ditemukan = false;
    for (int i = 0; i < jumlah; i++) {
        if (data[i].nim == hapus) {
            for (int j = i; j < jumlah - 1; j++) {
                data[j] = data[j + 1];
            }
            jumlah--;
            ditemukan = true;
            cout << "Data berhasil dihapus!\n";
            break;
        }
    }

    if (!ditemukan) {
        cout << "Data tidak ditemukan!\n";
    }
}

void sortingNIM() {
    for (int i = 0; i < jumlah - 1; i++) {
        for (int j = 0; j < jumlah - i - 1; j++) {
            if (stoi(data[j].nim) > stoi(data[j + 1].nim)) {
                swap(data[j], data[j + 1]);
            }
        }
    }
    cout << "Data berhasil diurutkan berdasarkan NIM!\n";
}

int main() {
    int pilihan;

    do {
        cout << "\n===== MENU ABSENSI MAHASISWA =====\n";
        cout << "1. Tambah Mahasiswa\n";
        cout << "2. Tampilkan Absen Mahasiswa\n";
        cout << "3. Cari Mahasiswa\n";
        cout << "4. Hapus Mahasiswa\n";
        cout << "5. Urutkan NIM Mahasiswa\n";
        cout << "0. Keluar\n";
        cout << "Pilih menu: ";
        cin >> pilihan;

        switch (pilihan) {
            case 1: tambahData(); break;
            case 2: tampilData(); break;
            case 3: cariData(); break;
            case 4: hapusData(); break;
            case 5: sortingNIM(); break;
            case 0: cout << "Program selesai.\n"; break;
            default: cout << "Pilihan tidak valid!\n";
        }

    } while (pilihan != 0);

    return 0;
}